{
  "name": "cypress-ithillel",
  "version": "1.0.0",
  "description": "Repository for learning and completing homework as part of the course at ITHillel school",
  "homepage": "https://github.com/sandrachupryna/cypress-ithillel#readme",
  "bugs": {
    "url": "https://github.com/sandrachupryna/cypress-ithillel/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/sandrachupryna/cypress-ithillel.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "cypress:open": "cypress open",
    "cypress:open:v1": "cypress open --config-file cypress.config.v1.js",
    "cypress:open:v2": "cypress open --config-file cypress.config.v2.js",
    "cypress:run:demo": "cypress run --spec 'cypress/examples/e2e/1-getting-started/*'",
    "cypress:run:v1": "cypress run --config-file cypress.config.v1.js --reporter mochawesome",
    "cypress:run:v2": "cypress run --config-file cypress.config.v2.js --reporter mochawesome",
    "merge-reports": "mochawesome-merge \"cypress/results/*.json\" > mochawesome-final-report.json && marge mochawesome-final-report.json && open-cli mochawesome-report/mochawesome-final-report.html",
    "clean:reports": "rm -rf cypress/results/*.json mochawesome-final-report.json",
    "pretest:mochawesome:full": "npm run clean:reports",
    "test:v1:mochawesome:full": "(npm run cypress:run:v1 || true) && npm run merge-reports",
    "test:v2:mochawesome:full": "(npm run cypress:run:v2 || true) && npm run merge-reports"
  },
  "devDependencies": {
    "@cypress/grep": "^5.1.0",
    "cypress": "^15.9.0",
    "dotenv": "^17.2.3",
    "mocha": "^11.3.0",
    "mochawesome": "^7.1.4",
    "mochawesome-merge": "^5.1.0",
    "mochawesome-report-generator": "^6.3.2",
    "open-cli": "^8.0.0"
  }
}
